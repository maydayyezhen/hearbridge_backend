<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yezhen.hearbridge.backend.mapper.GestureItemMapper">

    <select id="selectByCategoryId" resultType="com.yezhen.hearbridge.backend.entity.GestureItem">
        select
        id,
        category_id as categoryId,
        chinese_name as chineseName,
        label
        from gesture_item
        where category_id = #{categoryId}
    </select>

</mapper>
